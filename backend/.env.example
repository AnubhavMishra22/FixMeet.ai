# ===== Local Development =====
# NODE_ENV=development
# PORT=3001
# DATABASE_URL=postgres://fixmeet:fixmeet@localhost:5432/fixmeet
# JWT_SECRET=your-super-secret-key-at-least-32-characters-long
# FRONTEND_URL=http://localhost:5173

# ===== Production (DigitalOcean Droplet) =====
# Database (PostgreSQL on your droplet or managed DB)
DATABASE_URL=postgresql://user:password@host:5432/database

# JWT Secrets (generate secure random strings)
JWT_SECRET=generate-a-secure-random-string-min-32-chars

# Server
PORT=3001
NODE_ENV=production

# Frontend URL (your Vercel URL)
FRONTEND_URL=https://fixmeet.app

# Email (from Resend - https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=FixMeet <noreply@fixmeet.app>

# Google Calendar (from Google Cloud Console)
# Set up at https://console.cloud.google.com/
# Enable Google Calendar API, create OAuth 2.0 credentials
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
GOOGLE_REDIRECT_URI=https://api.fixmeet.app/api/calendars/google/callback

# AI Copilot (Optional - AI features disabled without this)
GOOGLE_AI_API_KEY=AIza...
# GOOGLE_AI_MODEL_NAME=gemini-2.5-flash-lite
# GOOGLE_AI_MAX_TOKENS=1024

# MCP Server (Optional - Model Context Protocol for AI clients)
# MCP_ENABLED=true
# MCP_RATE_LIMIT=30

# ===== Stripe billing (test mode) — required to exercise Checkout + webhooks =====
# Get keys from https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # Stripe CLI: stripe listen --forward-to localhost:3001/api/stripe/webhook
# Create two recurring Prices in Products; paste their price_ IDs:
# STRIPE_PRICE_ID_PRO=price_...
# STRIPE_PRICE_ID_MAX=price_...
# FRONTEND_URL is already set above — used for Checkout success/cancel and Portal return URLs.
# Optional: skip paid API checks while still running webhooks (showcase / demos)
# BILLING_SHOWCASE_MODE=false
